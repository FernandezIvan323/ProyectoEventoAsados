# Base de datos SQLite (ruta relativa a backend/)
DATABASE_URL="file:./dev.db"

# Puerto del servidor API
PORT=3000

# Origenes permitidos para CORS (separados por coma). Vacio = permitir todos en desarrollo.
# CORS_ORIGIN=http://localhost:5173

# Servir el frontend compilado desde el mismo servidor (produccion local)
# SERVE_FRONTEND=true

# Autenticacion local (opcional). Si AUTH_ENABLED=false, la API queda abierta.
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=cambiar-esta-clave
AUTH_SECRET=genera-un-secreto-largo-y-aleatorio

# ── Logging ─────────────────────────────────────────────
# Nivel: debug | info | warn | error
LOG_LEVEL=info
# Escribir logs a backend/logs/ (ademas de stdout)
LOG_TO_FILE=true
